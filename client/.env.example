# Copy to client/.env.local for local development.
# Only NEXT_PUBLIC_ values belong in this file. They are visible to the browser.

# The Express API. No direct application-data access from the client.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase client configuration for authentication only. New Supabase projects
# should use a publishable key. The client code will also accept the legacy
# NEXT_PUBLIC_SUPABASE_ANON_KEY name during migration.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Show only providers that are enabled and fully configured in the Supabase
# dashboard. OAuth remains authentication-only; it does not import work or
# request repository access.
# NEXT_PUBLIC_SUPABASE_OAUTH_PROVIDERS=google,github

# Legacy projects only:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
