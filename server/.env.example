# Copy to server/.env for local development.
# Never commit this file after replacing placeholders with real values.

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Server-only Supabase configuration. A secret key has service-role access and
# must never be exposed to the client or included in NEXT_PUBLIC_ variables.
# Leave both unset until this API is connected to a real project; private Build
# Brief persistence is intentionally unavailable rather than simulated without
# them.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_your-server-only-key
# Existing legacy projects only (do not set both variables):
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key

# JWT verification uses Supabase's public JWKS, derived from SUPABASE_URL.
# Set this only when a trusted deployment needs a different JWKS endpoint.
# Do not configure or rely on a legacy SUPABASE_JWT_SECRET.
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Server-only AI Assist provider chain: OpenAI -> OpenRouter -> deterministic
# fallback. Keep every provider key in this file only; never expose one through
# a NEXT_PUBLIC_ variable or commit it to source control.
#
# Preferred direct provider:
# OPENAI_API_KEY=your-openai-api-key
#
# Optional OpenRouter fallback for a configured open-weight model. If a model
# is omitted, the server uses its configured default. OpenRouter free-model
# availability and rate limits are variable; do not rely on them for a demo
# until the specific key and model have been tested.
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=provider/model-name
